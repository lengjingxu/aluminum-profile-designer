.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #111114;
  color: #ECECEE;
}

.top-bar {
  height: 52px;
  padding: 0 14px;
  background: #1A1A1F;
  border-bottom: 1px solid #2E2E38;
  display: flex;
  align-items: center;
  gap: 10px;
}

.title {
  font-size: 15px;
  font-weight: 600;
  color: #ECECEE;
}

.count {
  font-size: 12px;
  color: #888892;
  font-family: monospace;
  flex: 1;
}

.btn-save, .btn-danger {
  height: 36px;
  padding: 0 14px;
  border-radius: 8px;
  border: none;
  font-size: 13px;
  line-height: 36px;
}

.btn-save {
  background: rgba(255,255,255,0.08);
  color: #ECECEE;
}

.btn-danger {
  background: rgba(104,104,120,0.15);
  color: #888892;
}

.canvas {
  flex: 1;
  width: 100%;
  background: #0C0C0F;
}

.bottom-bar {
  height: 64px;
  background: #1A1A1F;
  border-top: 1px solid #2E2E38;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 8px;
}

.tool-btn {
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  border: none;
  background: transparent;
  color: #888892;
  font-size: 10px;
  cursor: pointer;
}

.tool-btn.active {
  background: #FFFFFF;
  color: #111114;
}
