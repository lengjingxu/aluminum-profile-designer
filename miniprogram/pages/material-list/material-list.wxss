.page-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #111114;
  color: #ECECEE;
}

.top-bar {
  height: 52px;
  padding: 0 14px;
  background: #1A1A1F;
  border-bottom: 1px solid #2E2E38;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  font-size: 15px;
  font-weight: 600;
  color: #ECECEE;
}

.btn-export {
  height: 36px;
  padding: 0 14px;
  border-radius: 8px;
  border: none;
  font-size: 13px;
  line-height: 36px;
  background: rgba(255,255,255,0.08);
  color: #ECECEE;
}

.summary {
  padding: 14px;
  background: #1A1A1F;
  border-bottom: 1px solid #2E2E38;
  display: flex;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.summary-label {
  font-size: 11px;
  color: #888892;
}

.summary-value {
  font-size: 14px;
  font-weight: 600;
  color: #ECECEE;
  font-family: monospace;
}

.material-list {
  flex: 1;
  padding: 12px;
}

.material-item {
  background: #1A1A1F;
  border: 1px solid #2E2E38;
  border-radius: 8px;
  padding: 12px 14px;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.material-profile {
  font-size: 14px;
  font-weight: 600;
  color: #ECECEE;
}

.material-count {
  font-size: 12px;
  color: #888892;
}

.material-length {
  font-size: 12px;
  color: #888892;
  font-family: monospace;
}

.empty-tip {
  text-align: center;
  padding: 40px 0;
  color: #888892;
  font-size: 13px;
}
